{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "model": "vercel/anthropic/claude-sonnet-4.6",
  "plugin": [
    "oh-my-openagent@latest",
    "@plannotator/opencode@latest",
    "opencode-cmux@latest",
  ],
  "experimental": {
    "disable_paste_summary": true,
  },
  "lsp": {
    "deno": {
      "disabled": true,
    },
  },
  "formatter": {
    "prettier": {
      "disabled": true,
    },
  },
}

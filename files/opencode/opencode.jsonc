{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "model": "vercel/anthropic/claude-sonnet-4.6",
  "plugin": ["./plugins/cmux-session.js", "oh-my-openagent"],
  "provider": {
    "vercel": {
      "models": {
        "openai/gpt-5.5": {
          "options": {
            "serviceTier": "priority",
          },
        },
        "openai/gpt-5.4-mini": {
          "options": {
            "serviceTier": "priority",
          },
        },
        "openai/gpt-5.3-codex": {
          "options": {
            "serviceTier": "priority",
          },
        },
        "anthropic/claude-opus-4.7": {
          "options": {
            "speed": "fast",
          },
        },
        "anthropic/claude-opus-4.8": {
          "options": {
            "speed": "fast",
          },
        },
      },
    },
  },
  "experimental": {
    "disable_paste_summary": true,
  },
  "lsp": {
    "deno": {
      "disabled": true,
    },
  },
  "formatter": {
    "prettier": {
      "disabled": true,
    },
  },
}

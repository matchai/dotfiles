{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/assets/oh-my-opencode.schema.json",
  "browser_automation_engine": {
    "provider": "agent-browser",
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
  },
  "mcp_env_allowlist": ["CONTEXT7_API_KEY"],
  "disabled_skills": ["dev-browser"],
  "agents": {
    "sisyphus": {
      "model": "vercel/anthropic/claude-opus-4.6",
      "variant": "max",
      "fallback_models": [
        {
          "model": "vercel/moonshotai/kimi-k2.5",
        },
        {
          "model": "vercel/openai/gpt-5.5",
          "variant": "medium",

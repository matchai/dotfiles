{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "vercel/anthropic/claude-opus-4.7",
      "variant": "max",
    },
    "hephaestus": {
      "model": "vercel/openai/gpt-5.5",
      "variant": "medium",
    },
    "oracle": {
      "model": "vercel/openai/gpt-5.5",
      "variant": "high",
      "prompt_append": "You have access to Context7 for looking up library and framework documentation. Use it when you need accurate, up-to-date API details rather than relying on training data.",
    },
    "librarian": {
      "model": "vercel/openai/gpt-5.4-mini",
    },
    "explore": {
      "model": "vercel/openai/gpt-5.4-mini",
    },
    "multimodal-looker": {
      "model": "vercel/openai/gpt-5.5",
      "variant": "medium",
    },
    "prometheus": {
      "model": "vercel/anthropic/claude-opus-4.7",
      "variant": "max",
    },
    "metis": {
      "model": "vercel/anthropic/claude-sonnet-4.6",
    },
    "momus": {
      "model": "vercel/openai/gpt-5.5",
      "variant": "xhigh",
    },
    "atlas": {
      "model": "vercel/anthropic/claude-sonnet-4.6",
    },
    "sisyphus-junior": {
      "model": "vercel/anthropic/claude-sonnet-4.6",
    },
  },
  "categories": {
    "visual-engineering": {
      "model": "vercel/google/gemini-3.1-pro-preview",
      "variant": "high",
    },
    "ultrabrain": {
      "model": "vercel/openai/gpt-5.5",
      "variant": "xhigh",
    },
    "deep": {
      "model": "vercel/openai/gpt-5.5",
      "variant": "medium",
    },
    "artistry": {
      "model": "vercel/google/gemini-3.1-pro-preview",
      "variant": "high",
    },
    "quick": {
      "model": "vercel/openai/gpt-5.4-mini",
    },
    "unspecified-low": {
      "model": "vercel/anthropic/claude-sonnet-4.6",
    },
    "unspecified-high": {
      "model": "vercel/anthropic/claude-opus-4.7",
      "variant": "max",
    },
    "writing": {
      "model": "vercel/google/gemini-3-flash",
    },
  },
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 4,
    "max_members": 8,
    "tmux_visualization": false,
  },
  "browser_automation_engine": {
    "provider": "agent-browser",
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
  },
  "mcp_env_allowlist": ["CONTEXT7_API_KEY"],
  "disabled_skills": ["dev-browser"],
  "disabled_hooks": ["todo-continuation-enforcer"],
}

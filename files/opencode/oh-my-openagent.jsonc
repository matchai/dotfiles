{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/assets/oh-my-opencode.schema.json",
  "browser_automation_engine": {
    "provider": "agent-browser",
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
  },
  "disabled_skills": ["dev-browser", "playwright"],
  "agents": {
    "sisyphus": {
      "model": "vercel/anthropic/claude-opus-4.6",
      "variant": "max",
      "permission": {
        "bash": "allow",
      },
    },
    "hephaestus": {
      "model": "vercel/openai/gpt-5.4",
      "variant": "medium",
    },
    "oracle": {
      "model": "vercel/openai/gpt-5.4",
      "variant": "high",
    },
    "librarian": {
      "model": "vercel/anthropic/claude-haiku-4.5",
    },
    "explore": {
      "model": "vercel/anthropic/claude-haiku-4.5",
    },
    "multimodal-looker": {
      "model": "vercel/openai/gpt-5.4",
      "variant": "medium",
    },
    "prometheus": {
      "model": "vercel/anthropic/claude-opus-4.6",
      "variant": "max",
    },
    "metis": {
      "model": "vercel/anthropic/claude-opus-4.6",
      "variant": "max",
    },
    "momus": {
      "model": "vercel/openai/gpt-5.4",
      "variant": "x-high",
    },
    "atlas": {
      "model": "vercel/anthropic/claude-sonnet-4.6",
    },
    "sisyphus-junior": {
      "model": "vercel/anthropic/claude-sonnet-4.6",
    },
  },
  "categories": {
    "visual-engineering": {
      "model": "vercel/google/gemini-3.1-pro-preview",
      "variant": "high",
    },
    "ultrabrain": {
      "model": "vercel/openai/gpt-5.4",
      "variant": "xhigh",
    },
    "deep": {
      "model": "vercel/openai/gpt-5.4",
      "variant": "medium",
    },
    "artistry": {
      "model": "vercel/google/gemini-3.1-pro-preview",
      "variant": "high",
    },
    "quick": {
      "model": "vercel/openai/gpt-5.4-mini",
    },
    "unspecified-low": {
      "model": "vercel/anthropic/claude-sonnet-4.6",
    },
    "unspecified-high": {
      "model": "vercel/anthropic/claude-sonnet-4.6",
    },
    "writing": {
      "model": "vercel/google/gemini-3-flash",
    },
  },
}
